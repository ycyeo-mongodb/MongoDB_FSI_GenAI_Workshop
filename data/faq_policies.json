[
  {
    "id": "FAQ-001",
    "title_en": "Personal loan APR range",
    "title_km": "бһўбһҸбҹ’бһҡбһ¶бһҖбһ¶бһҡбһ”бҹ’бһҡбһ¶бһҖбҹӢбһҖбһҳбҹ’бһ…бһёбһ”бһ»бһӮбҹ’бһӮбһӣ",
    "content_en": "The bank offers personal loans with annual percentage rates between 12% and 18% APR depending on credit profile, tenor, and collateral. Rates are fixed for the agreed term.",
    "content_km": "бһ’бһ“бһ¶бһӮбһ¶бһҡ бһҹбһ¶бһ’бһ¶бһҡбһҺбҹҲ бһ•бҹ’бһҸбһӣбҹӢбһҖбһҳбҹ’бһ…бһёбһ”бһ»бһӮбҹ’бһӮбһӣбһҠбҹӮбһӣбһҳбһ¶бһ“бһўбһҸбҹ’бһҡбһ¶бһҖбһ¶бһҡбһ”бҹ’бһҡбһ¶бһҖбҹӢбһ”бҹ’бһҡбһ…бһ¶бҹҶбһҶбҹ’бһ“бһ¶бҹҶбһ–бһё бҹЎбҹў% бһҠбһӣбҹӢ бҹЎбҹЁ% бһўбһ¶бһҹбҹ’бһҡбҹҗбһҷбһӣбһҫбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҘбһҺбһ‘бһ¶бһ“ бһҡбһҷбҹҲбһ–бҹҒбһӣ бһ“бһ·бһ„бһ‘бҹ’бһҡбһ–бҹ’бһҷбһ”бһүбҹ’бһ…бһ¶бҹҶбҹ” бһўбһҸбҹ’бһҡбһ¶бһҗбҹҒбһҡбһҸбһ¶бһҳбһҡбһҷбҹҲбһ–бҹҒбһӣбһҠбҹӮбһӣбһ”бһ¶бһ“бһ–бҹ’бһҡбһҳбһ–бҹ’бһҡбҹҖбһ„бҹ”",
    "category": "loans",
    "department": "Retail Lending"
  },
  {
    "id": "FAQ-002",
    "title_en": "Minimum balance savings USD",
    "title_km": "бһҹбһҳбһҸбһ»бһӣбҹ’бһҷбһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶бһӮбһҺбһ“бһёбһҹбһ“бҹ’бһҹбҹҶ USD",
    "content_en": "Standard savings accounts in USD require a minimum balance of USD 10 to avoid monthly service fees. Premium tiers may require USD 500.",
    "content_km": "бһӮбһҺбһ“бһёбһҹбһ“бҹ’бһҹбҹҶбһҮбһ¶бһ”бҹ’бһҡбһ¶бһҖбҹӢбһҠбһ»бһӣбҹ’бһӣбһ¶бһҡбһҸбһҳбҹ’бһҡбһјбһңбһІбҹ’бһҷбһҳбһ¶бһ“бһҹбһҳбһҸбһ»бһӣбҹ’бһҷбһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶ бҹЎбҹ  бһҠбһ»бһӣбҹ’бһӣбһ¶бһҡбһҠбһҫбһҳбҹ’бһ”бһёбһҮбҹҖбһҹбһңбһ¶бһ„бһҗбҹ’бһӣбҹғбһҹбҹҒбһңбһ¶бһ”бҹ’бһҡбһ…бһ¶бҹҶбһҒбҹӮбҹ” бһҖбһҳбҹ’бһҡбһ·бһҸбһ–бһ·бһҹбҹҒбһҹбһўбһ¶бһ…бһҸбһҳбҹ’бһҡбһјбһң бҹҘбҹ бҹ  бһҠбһ»бһӣбҹ’бһӣбһ¶бһҡбҹ”",
    "category": "accounts",
    "department": "Deposits"
  },
  {
    "id": "FAQ-003",
    "title_en": "Minimum balance savings KHR",
    "title_km": "бһҹбһҳбһҸбһ»бһӣбҹ’бһҷбһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶бһӮбһҺбһ“бһёбһҹбһ“бҹ’бһҹбҹҶ KHR",
    "content_en": "KHR savings accounts maintain a minimum balance of KHR 50,000. Falling below may incur a small maintenance charge unless waived for payroll clients.",
    "content_km": "бһӮбһҺбһ“бһёбһҹбһ“бҹ’бһҹбҹҶбһҡбҹҖбһӣбһҸбһҳбҹ’бһҡбһјбһңбһҡбһҖбҹ’бһҹбһ¶бһҹбһҳбһҸбһ»бһӣбҹ’бһҷбһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶ бҹҘбҹ ,бҹ бҹ бҹ  бһҡбҹҖбһӣбҹ” бһ”бһҫбһ‘бһ¶бһ”бһҮбһ¶бһ„бһ“бҹҒбҹҮбһўбһ¶бһ…бһҳбһ¶бһ“бһҗбҹ’бһӣбҹғбһҗбҹӮбһ‘бһ¶бҹҶбһӣбһҫбһҖбһӣбҹӮбһ„бһҸбҹӮбһўбһҸбһ·бһҗбһ·бһҮбһ“бһ”бҹ’бһҡбһ¶бһҖбҹӢбһҒбҹӮбҹ”",
    "category": "accounts",
    "department": "Deposits"
  },
  {
    "id": "FAQ-004",
    "title_en": "KYC for new accounts",
    "title_km": "бһҸбһҫбһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһўбҹ’бһңбһёбһҒбҹ’бһӣбҹҮбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ KYC?",
    "content_en": "Account opening requires valid national ID or passport, proof of address (utility bill or lease within 90 days), and for business accounts, enterprise registration and beneficial ownership forms.",
    "content_km": "бһҖбһ¶бһҡбһ”бһҫбһҖбһӮбһҺбһ“бһёбһҸбһҳбҹ’бһҡбһјбһңбһўбһҸбҹ’бһҸбһҹбһүбҹ’бһүбһ¶бһҺбһ”бҹҗбһҺбҹ’бһҺбһҮбһ¶бһҸбһ· бһ¬бһӣбһ·бһҒбһ·бһҸбһҶбҹ’бһӣбһ„бһҠбҹӮбһ“ бһ—бһҹбҹ’бһҸбһ»бһҸбһ¶бһ„бһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“ (бһңбһ·бһҖбҹ’бһҖбһҷбһ”бһҸбҹ’бһҡбһҹбһ¶бһ’бһ¶бһҡбһҺбҹҲ бһ¬бһҖбһ·бһ…бҹ’бһ…бһҹбһ“бҹ’бһҷбһ¶бһҮбһҪбһӣбһҖбҹ’бһ“бһ»бһ„ бҹ©бҹ  бһҗбҹ’бһ„бҹғ) бһ“бһ·бһ„бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһӮбһҺбһ“бһёбһўбһ¶бһҮбһёбһңбһҖбһҳбҹ’бһҳ бһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһ…бһ»бҹҮбһ”бһүбҹ’бһҮбһёбһ’бһ»бһҡбһҖбһ·бһ…бҹ’бһ… бһ“бһ·бһ„бһ‘бһҳбҹ’бһҡбһ„бҹӢбһҳбҹ’бһ…бһ¶бһҹбҹӢбһўбһ¶бһҮбһёбһңбһҖбһҳбҹ’бһҳбһ–бһ·бһҸбһ”бҹ’бһҡбһ¶бһҖбһҠбҹ”",
    "category": "compliance",
    "department": "AML & KYC"
  },
  {
    "id": "FAQ-005",
    "title_en": "Annual leave for staff",
    "title_km": "бһ…бҹ’бһ”бһ¶бһ”бҹӢбһҲбһ”бҹӢбһҹбһҳбҹ’бһҡбһ¶бһҖбһ”бҹ’бһҡбһ…бһ¶бҹҶбһҶбҹ’бһ“бһ¶бҹҶ",
    "content_en": "Full-time employees accrue 18 working days of annual leave per year after probation. Carry-forward is limited to 5 days unless approved by HR.",
    "content_km": "бһ”бһ»бһӮбҹ’бһӮбһӣбһ·бһҖбһ–бҹҒбһүбһҳбҹүбҹ„бһ„бһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһ…бҹ’бһ”бһ¶бһ”бҹӢбһҲбһ”бҹӢбһҹбһҳбҹ’бһҡбһ¶бһҖ бҹЎбҹЁ бһҗбҹ’бһ„бҹғбһҖбһ¶бһҡбһҖбҹ’бһ“бһ»бһ„бһҳбһҪбһҷбһҶбҹ’бһ“бһ¶бҹҶбһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһ–бһёбһҡбһҷбҹҲбһ–бҹҒбһӣбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„бҹ” бһҖбһ¶бһҡбһ•бҹ’бһ‘бҹҒбһҡбһҶбҹ’бһ“бһ¶бҹҶбһҖбҹҶбһҺбһҸбҹӢ бҹҘ бһҗбҹ’бһ„бҹғбһӣбһҫбһҖбһӣбҹӮбһ„бһҸбҹӮбһ•бҹ’бһ“бҹӮбһҖбһ’бһ“бһ’бһ¶бһ“бһҳбһ“бһ»бһҹбҹ’бһҹбһўбһ“бһ»бһҳбҹҗбһҸбҹ”",
    "category": "hr",
    "department": "Human Resources"
  },
  {
    "id": "FAQ-006",
    "title_en": "Sick leave policy",
    "title_km": "бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ…бҹ’бһ”бһ¶бһ”бҹӢбһҲбһ”бҹӢбһҹбһҳбҹ’бһҡбһ¶бһҖбһҲбһә",
    "content_en": "Staff may use up to 7 paid sick days annually with medical certificate for absences longer than 2 consecutive days.",
    "content_km": "бһ”бһ»бһӮбҹ’бһӮбһӣбһ·бһҖбһўбһ¶бһ…бһ”бҹ’бһҡбһҫбһ…бҹ’бһ”бһ¶бһ”бҹӢбһҲбһәбһҳбһ¶бһ“бһ”бҹ’бһҡбһ¶бһҖбҹӢбһҲбҹ’бһ“бһҪбһӣбһҡбһ бһјбһҸбһҠбһӣбҹӢ бҹ§ бһҗбҹ’бһ„бҹғбһҖбҹ’бһ“бһ»бһ„бһҳбһҪбһҷбһҶбҹ’бһ“бһ¶бҹҶ бһ“бһ·бһ„бһҸбһҳбҹ’бһҡбһјбһңбһӣбһ·бһҒбһ·бһҸбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢбһ–бһёбһӮбҹ’бһҡбһјбһ–бҹҒбһ‘бҹ’бһҷбһ”бһҫбһўбһңбһҸбҹ’бһҸбһҳбһ¶бһ“бһӣбһҫбһҹбһ–бһё бҹў бһҗбҹ’бһ„бҹғбһҮбһ¶бһ”бҹӢбһӮбҹ’бһ“бһ¶бҹ”",
    "category": "hr",
    "department": "Human Resources"
  },
  {
    "id": "FAQ-007",
    "title_en": "Mobile banking security",
    "title_km": "бһҹбһ»бһңбһҸбҹ’бһҗбһ·бһ—бһ¶бһ–бһ’бһ“бһ¶бһӮбһ¶бһҡбһ…бһӣбҹҗбһҸ",
    "content_en": "Do not share OTPs or PINs. Enable biometric login where available. Report lost devices immediately. The bank never asks for passwords by phone or SMS.",
    "content_km": "бһҖбһ»бҹҶбһ…бҹӮбһҖбһҡбҹҶбһӣбҹӮбһҖбһӣбҹҒбһҒ OTP бһ¬ PINбҹ” бһ”бһҫбһҖбһ”бҹ’бһҡбһҫбһҖбһ¶бһҡбһ…бһјбһӣбһҠбҹ„бһҷбһҹбһҳбҹ’бһӮбһ¶бһӣбҹӢбһҮбһёбһңбһҳбһ¶бһҸбҹ’бһҡбҹ” бһҡбһ¶бһҷбһҖбһ¶бһҡбһҺбҹҚбһ§бһ”бһҖбһҡбһҺбҹҚбһ”бһ¶бһҸбҹӢбһ—бҹ’бһӣбһ¶бһҳбҹ—бҹ” бһ’бһ“бһ¶бһӮбһ¶бһҡбһҳбһ·бһ“бһҹбһҪбһҡбһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢбһҸбһ¶бһҳбһ‘бһјбһҡбһҹбҹҗбһ–бҹ’бһ‘ бһ¬ SMS бһЎбһҫбһҷбҹ”",
    "category": "digital_banking",
    "department": "Digital Channels"
  },
  {
    "id": "FAQ-008",
    "title_en": "Device binding rules",
    "title_km": "бһ…бҹ’бһ”бһ¶бһ”бҹӢбһ—бҹ’бһҮбһ¶бһ”бҹӢбһ§бһ”бһҖбһҡбһҺбҹҚ",
    "content_en": "Each mobile banking profile may be active on one primary handset; secondary device registration requires branch or video verification.",
    "content_km": "бһӮбһҺбһ“бһёбһ’бһ“бһ¶бһӮбһ¶бһҡбһ…бһӣбҹҗбһҸбһҳбһҪбһҷбһўбһ¶бһ…бһҹбһҖбһҳбҹ’бһҳбһӣбһҫбһ‘бһјбһҡбһҹбҹҗбһ–бҹ’бһ‘бһҳбһҪбһҷбһҮбһ¶бһ…бһҳбҹ’бһ”бһ„ бһҖбһ¶бһҡбһ…бһ»бҹҮбһҲбҹ’бһҳбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһ‘бһёбһ–бһёбһҡбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһ“бҹ…бһҹбһ¶бһҒбһ¶ бһ¬бһңбһёбһҠбҹҒбһўбһјбҹ”",
    "category": "digital_banking",
    "department": "Digital Channels"
  },
  {
    "id": "FAQ-009",
    "title_en": "Loan disbursement steps",
    "title_km": "бһҮбҹҶбһ бһ¶бһ“бһ”бһүбҹ’бһ…бҹҒбһүбһ”бҹ’бһҡбһ¶бһҖбҹӢбһҖбһҳбҹ’бһ…бһё",
    "content_en": "After approval, disbursement occurs to the borrowerвҖҷs designated account within 2 business days once collateral registration (if any) and signed agreements are complete.",
    "content_km": "бһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһ–бһёбһўбһ“бһ»бһҳбҹҗбһҸ бһ”бҹ’бһҡбһ¶бһҖбҹӢбһҖбһҳбҹ’бһ…бһёбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бһүбҹ’бһ…бһјбһӣбһ‘бҹ…бһӮбһҺбһ“бһёбһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҖбҹ’бһ“бһ»бһ„бһҡбһҷбҹҲбһ–бҹҒбһӣ бҹў бһҗбҹ’бһ„бҹғбһ’бҹ’бһңбһҫбһҖбһ¶бһҡ бһ“бҹ…бһ–бҹҒбһӣбһ…бһ»бҹҮбһ”бһүбҹ’бһҮбһёбһ‘бҹ’бһҡбһ–бҹ’бһҷбһ”бһүбҹ’бһ…бһ¶бҹҶ (бһ”бһҫбһҳбһ¶бһ“) бһ“бһ·бһ„бһҖбһ·бһ…бҹ’бһ…бһҹбһ“бҹ’бһҷбһ¶бһ”бһ¶бһ“бһ…бһ»бҹҮбһ бһҸбҹ’бһҗбһӣбҹҒбһҒбһ¶бһҡбһҪбһ…бҹ”",
    "category": "loans",
    "department": "Retail Lending"
  },
  {
    "id": "FAQ-010",
    "title_en": "Collateral for secured loans",
    "title_km": "бһ‘бҹ’бһҡбһ–бҹ’бһҷбһ”бһүбҹ’бһ…бһ¶бҹҶбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһҳбҹ’бһ…бһёбһҳбһ¶бһ“бһҖбһ¶бһҡбһ’бһ¶бһ“бһ¶",
    "content_en": "Accepted collateral includes registered immovable property, insured vehicles, and cash deposits. LTV limits apply; valuations must be from approved appraisers.",
